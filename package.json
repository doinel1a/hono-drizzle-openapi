  "author": {
    "name": "Doinel Atanasiu",
    "email": "doinel+github@atanasiu.me",
    "url": "https://business-link.d1a.app"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/doinel1a/node-ts-base"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "tsx src/env.ts && tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write **/**/*.{js,mjs,cjs,ts,mts,cts} --cache",
    "db:studio": "drizzle-kit --config=db/config.ts studio",
    "db:push": "drizzle-kit --config=db/config.ts push",
    "db:create-migration": "drizzle-kit --config=db/config.ts generate",
    "db:migrate": "drizzle-kit --config=db/config.ts migrate"
  },
  "dependencies": {
    "@hono/node-server": "1.19.11",
    "@hono/zod-openapi": "1.2.2",
    "@loglayer/hono": "2.1.0",
    "@loglayer/transport-simple-pretty-terminal": "3.0.2",
    "@scalar/hono-api-reference": "0.10.4",
    "@t3-oss/env-core": "0.13.10",
    "dotenv": "17.3.1",
    "drizzle-orm": "0.45.1",
    "hono": "4.12.8",
    "loglayer": "9.1.0",
    "pg": "8.20.0",
    "serialize-error": "13.0.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@types/node": "25.5.0",
    "@types/pg": "8.18.0",
    "drizzle-kit": "0.31.10",
    "eslint": "10.0.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-drizzle": "0.2.3",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-sonarjs": "4.0.2",
    "eslint-plugin-unicorn": "63.0.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "3.8.1",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.1"
  }
}
